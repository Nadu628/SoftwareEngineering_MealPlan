<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.mealprepmain.SignUpScreenController"
            prefHeight="400.0" prefWidth="600.0">

    <BorderPane AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
        <center>
            <VBox alignment="CENTER" spacing="15" maxWidth="400">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Create Your Account" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                <GridPane vgap="10" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="150"/>
                        <ColumnConstraints prefWidth="250"/>
                    </columnConstraints>

                    <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Confirm Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>

                <!-- Add button section here -->
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="createAccountButton" onAction="#handleCreateAccount" text="Create Account"/>
                    <Button fx:id="backToLoginButton" text="Back to Login"/>
                </HBox>
            </VBox>
        </center>
    </BorderPane>
</AnchorPane>